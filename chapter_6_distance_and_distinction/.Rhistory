# If we quit R studio, we will need to reload the libraries
library(tidyverse)
library(hansardr)
library(tidytext)
library(dhmeasures)
# Load Hansard data for the 1840s and 1850s
data("hansard_1840")
data("hansard_1850")
# preprocess the 1840s hansard data
hansard_1840 <- hansard_1840 %>%
unnest_tokens(word, text) %>%
anti_join(stop_words) %>%
filter(!str_detect(word, "[:digit:]")) %>%
mutate(decade = 1840)
# preprocess the 1850s hansard data
hansard_1850 <- hansard_1850 %>%
unnest_tokens(word, text) %>%
anti_join(stop_words) %>%
filter(!str_detect(word, "[:digit:]")) %>%
mutate(decade = 1850)
# combine both decades
hansard_combined <- bind_rows(hansard_1840, hansard_1850)
# count each word within each decade
hansard_counts <- hansard_combined %>%
count(decade, word)
# calculate JSD contributions for each word
output <- jsd(hansard_counts,
group = "decade",
group_list = c(1840, 1850)) %>%
rename(jsd = 2)
# keep only the top contributing words
word_dist_top <- output %>%
slice_max(order_by = jsd, n = 20)
# plot
ggplot(word_dist_top,
aes(x = reorder(word, jsd),      # order words by JSD value
y = jsd)) +                  # plot JSD values on the y-axis
geom_col() +                                      # create a bar chart
coord_flip() +                                    # flip axes for easier reading
labs(title = "JSD of Top Words: 1840s vs. 1850s", # chart title
x = "Word",                                  # x-axis label
y = "JSD Value")                             # y-axis label
# calculate JSD contributions
word_dist_top <- jsd(hansard_counts,
group = "decade",
group_list = c("1840s", "1850s")) %>%
rename(jsd = 2) %>%                          # rename the JSD score column
slice_max(jsd, n = 20)                       # keep the top 20 words
# plot top JSD words
ggplot(word_dist_top,
aes(x = reorder(word, jsd),             # order words by JSD score
y = jsd)) +                         # plot JSD score
geom_col() +                                 # create bar chart
coord_flip() +                               # flip axes for readability
labs(title = "JSD of Top Words: 1840s vs. 1850s",
x = "Word",
y = "JSD Value")
# calculate JSD contributions
word_dist <- jsd(hansard_counts,
group = "decade",
group_list = c("1840s", "1850s")) %>%
rename(jsd = 2)                                   # rename JSD score column
# calculate word proportions by decade
word_props <- hansard_counts %>%
group_by(decade) %>%                              # work within each decade
mutate(prop = n / sum(n)) %>%                     # calculate relative frequency
select(decade, word, prop) %>%                    # keep needed columns
pivot_wider(names_from = decade,
values_from = prop,
values_fill = 0)                      # make one column per decade
# combine JSD with direction
word_dist <- word_dist %>%
left_join(word_props, by = "word") %>%            # add decade proportions
mutate(decade_more_common = if_else(`1840s` > `1850s`,
"More common in 1840s",
"More common in 1850s"))
View(hansard_combined)
# calculate JSD contributions
word_dist <- jsd(hansard_counts,
group = "decade",
group_list = c(1840, 1850)) %>%
rename(jsd = 2)
# calculate word proportions by decade
word_props <- hansard_counts %>%
group_by(decade) %>%
mutate(prop = n / sum(n)) %>%
select(decade, word, prop) %>%
pivot_wider(names_from = decade,
values_from = prop,
values_fill = 0)
# identify which decade each word is more associated with
word_dist <- word_dist %>%
left_join(word_props, by = "word") %>%
mutate(decade_more_common = if_else(`1840` > `1850`,
"More common in 1840",
"More common in 1850"))
# keep the 10 most distinctive words for each decade
word_dist_top <- word_dist %>%
group_by(decade_more_common) %>%
slice_max(jsd, n = 10) %>%
ungroup()
# plot
ggplot(word_dist_top,
aes(x = reorder(word, jsd),
y = jsd,
fill = decade_more_common)) +
geom_col() +
coord_flip() +
labs(title = "Most Distinctive Words: 1840 vs. 1850",
x = "Word",
y = "JSD Value",
fill = "More Common In")
# calculate JSD contributions
