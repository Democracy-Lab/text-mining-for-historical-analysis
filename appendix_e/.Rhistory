# choose the correct folder and Python file based on the operating system
# Windows uses Scripts/python.exe
# macOS and Linux use bin/python
if (.Platform$OS.type == "windows") {
python_folder <- "Scripts"
python_file <- "python.exe" }
else if (.Platform$OS.type == "unix") {
# choose the correct folder and Python file based on the operating system
# Windows uses Scripts/python.exe
# macOS and Linux use bin/python
