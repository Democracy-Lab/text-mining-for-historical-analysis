# Find the most frequent words used by speakers recorded as Chancellor of the Exchequer
# - filter() keeps just relevant speakers and valid words
# - anti_join() removes stop words
# - group_by() groups words by suggested speaker
# - summarize() counts how often each word was used
# - top_n() keeps the 35 most frequent results
# - ungroup() removes the grouping
chancellor_of_the_exchequeur <- words_1830 %>%
filter(str_detect(speaker, "Exchequer"), # Find speakers
str_detect(word, "[a-z]"), # Keep alphabetic words
suggested_speaker != "", # Remove unidentified speakers
suggested_speaker != "chancellor of the exchequerr") %>% # Remove OCR errpr
anti_join(stop_words) %>% # Remove stop words
anti_join(custom_stop_words) %>% # Remove custom stop words
group_by(suggested_speaker, word) %>% # Group by speaker and word
summarize(n = n()) %>% # Count word frequency
top_n(35) %>% # Keep top 35
ungroup() # Remove grouping
# Show five random results
chancellor_of_the_exchequeur %>%
sample_n(5)
# Reorder words within each speaker and visualize their most frequent words
# - mutate() reorders words based on frequency within each speaker
# - ggplot() creates the visualization
# - geom_col() creates bars showing word frequency
# - scale_x_reordered() displays the reordered word labels
# - coord_flip() flips the axes for readability
# - facet_wrap() creates a separate panel for each speaker
# - labs() labels the axes
# - ggtitle() adds the graph title
ggplot(data = chancellor_of_the_exchequeur %>%
mutate(word = reorder_within(word, n, suggested_speaker)), # Reorder words by speaker
aes(x = word, y = n)) + # Set axes
geom_col() + # Create bars
scale_x_reordered() + # Reorder word labels
coord_flip() + # Flip axes
facet_wrap(~suggested_speaker, scales = "free") + # Separate by speaker
labs(x = "word", y = "number of uses") + # Label axes
ggtitle("Favorite Words of Each Chancellor of the Exchequer in the 1830s") # Add title
# Convert a character date into a date object
date1 <- mdy("6/24/1819")
date1
# Extract the year from the date
year1 <- year(date1)
year1
# Load debate metadata for the 1830s
data("debate_metadata_1830")
# Join debate metadata and add the year of each speech
hansard_1830_w_year <- hansard_1830 %>%
left_join(debate_metadata_1830) %>%
mutate(year = year(speechdate))
# Display formatted top text
hansard_1830_w_year %>%
head() %>%
mutate(text = str_trunc(text, 120)) %>%
kable()
# Remove the old words_1830 dataset from memory
rm(words_1830)
gc() # Free up memory
# Create a tokenized dataset that includes the year of each speech
words_1830_w_year <- hansard_1830_w_year %>%
left_join(speaker_metadata_1830) %>% # Add speaker metadata
select(speaker, suggested_speaker, text, year) %>% # Keep relevant columns
unnest_tokens(word, text) # Split the speech text into individual words
# Look at the first few rows of the tokenized dataset
words_1830_w_year %>%
head() %>%
select(speaker, word, year) %>% # Show the speaker, word, and year
kable()
# Count the number of words spoken by each speaker per year
# - filter() removes rows without a suggested speaker
# - group_by() groups words by speaker and year
# - summarize() counts the total words for each speaker per year
# - arrange() sorts speakers from highest to lowest word count
words_per_speaker_1830 <- words_1830_w_year %>%
filter(suggested_speaker != "") %>% # Keep identified speakers
group_by(speaker, year) %>% # Group by speaker and year
summarize(speaker_words_per_year = n()) %>% # Count words
arrange(desc(speaker_words_per_year)) # Sort by word count
# Display the first six rows of speaker word counts
head(words_per_speaker_1830)
