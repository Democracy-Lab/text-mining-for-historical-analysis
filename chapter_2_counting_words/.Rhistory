# Load the needed libraries
library(tidytext)
library(tidyverse)
library(lubridate)
library(kableExtra) # DO I still use this? <------------------------------------------------
library(hansardr)
library(ggrepel)
library(scales)
# Load speaker metadata for 1830
data("speaker_metadata_1830")
head(speaker_metadata_1830)
# Load Hansard data
data("hansard_1830") # 1830s speech text
data("speaker_metadata_1830") # 1830s speaker metadata
# Join speaker data and tokenize text
words_1830 <- hansard_1830 %>%
left_join(speaker_metadata_1830) %>% # Add speaker metadata
select(speaker, suggested_speaker, text) %>% # Keep relevant columns
unnest_tokens(word, text) # Split text into words
# Display first six rows
head(words_1830)
# Group words by speaker
words_per_speaker_1830 <- words_1830 %>%
group_by(speaker)
# Group words by suggested speaker
words_per_speaker_1830 <- words_1830 %>%
group_by(suggested_speaker)
# Count the total number of words spoken by each speaker
# - group_by() groups all words by speaker
# - summarize() counts the number of words spoken by each speaker
# - arrange() sorts speakers from most to least words spoken
words_per_speaker_1830 <- words_1830 %>%
group_by(speaker) %>% # Group by speaker
summarize(words_spoken = n()) %>% # Count words
arrange(desc(words_spoken)) # Sort highest to lowest
# Display the first six speakers
head(words_per_speaker_1830)
# Count words spoken by each identified speaker
# - filter() removes rows without a suggested speaker
# - group_by() groups words by the standardized speaker name
# - summarize() counts the number of words spoken by each speaker
# - arrange() sorts speakers from most to least words spoken
words_per_speaker_1830 <- words_1830 %>%
filter(suggested_speaker != "") %>% # Remove unidentified speakers
group_by(suggested_speaker) %>% # Group by suggested speaker
summarize(words_spoken = n()) %>% # Count words
arrange(desc(words_spoken)) # Sort highest to lowest
head(words_per_speaker_1830)
