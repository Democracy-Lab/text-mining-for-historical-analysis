# Display the first six rows of speaker word counts
head(words_per_speaker_1830)
data("hansard_1820")
data("speaker_metadata_1820")
data("file_metadata_1820")
# Find speaker metadata for Mrs. Walrand
# - str_detect() searches the speaker names for "Mrs" followed by "Walrand"
# - regex() makes the search case insensitive
mrs_walrand_speaker_metadata <- speaker_metadata_1820 %>%
filter(str_detect(speaker, regex("Mrs(.*)Walrand", ignore_case = TRUE))) # Find Mrs. Walrand
# Add sentence text and debate information for Mrs. Walrand
# - left_join() connects the speaker metadata to the file metadata using sentence ID
# - The second left_join() adds the corresponding Hansard text
# - select() keeps only the debate ID and text
mrs_walrand_sentences <- left_join(mrs_walrand_speaker_metadata,
file_metadata_1820, by = "sentence_id") %>% # Add file metadata
left_join(., hansard_1820, by = "sentence_id") %>% # Add Hansard text
select(debate_id, text) # Keep relevant columns
# Display sample sentences by Mrs. Walrand
mrs_walrand_sentences %>%
head() %>%
mutate(text = str_trunc(text, 120)) %>%
kable(caption = "Sentences uttered by Mrs. Walrand in the 1820 Hansard debates.")
# Extract the text from the debate of interest
# - left_join() adds file metadata to the Hansard data using sentence ID
# - filter() keeps only sentences from debate with the ID 5142
# - select() keeps only the text column
entire_debate <- hansard_1820 %>%
left_join(file_metadata_1820, by = "sentence_id") %>% # Add file metadata
filter(debate_id == 5142) %>% # Keep debate 5142
select(text) # Keep the text column
# Create a table containing the first 20 sentences of the debate
debate_table <- tibble(text = head(entire_debate$text, 20)) # Keep first 20 sentences
# Display the first 20 sentences of the debate as a formatted table
debate_table %>%
kable(caption = "Excerpt of Debate Text (First 20 Sentences)")
# Find Mrs. Walrand's 30 most frequently used words
# - left_join() adds the Hansard text to Mrs. Walrand's speaker metadata
# - unnest_tokens() splits the text into individual lowercase words
# - anti_join() removes common stop words
# - filter() removes numbers from the word list
# - group_by() groups words by speaker and word
# - summarize() counts how often each word occurs
# - arrange() sorts the words from most to least frequent
# - top_n() keeps the 30 most frequent words
mrs_walrand_top_words <- left_join(mrs_walrand_speaker_metadata, hansard_1820) %>%
unnest_tokens(word, text) %>% # Tokenize text
anti_join(stop_words) %>% # Remove stop words
filter(is.na(as.numeric(word))) %>% # Remove numbers
group_by(speaker, word) %>% # Group by speaker and word
summarize(n = n()) %>% # Count words
arrange(desc(n)) %>% # Sort by frequency
top_n(30) # Keep top 30 words
# Create a bar chart of Mrs. Walrand's most frequently used words
# - ggplot() assigns words to the x-axis and word counts to the y-axis
# - reorder() orders words by their frequency
# - geom_col() creates bars based on the word counts
# - coord_flip() flips the axes to make the words easier to read
# - labs() adds the title, subtitle, and axis labels
ggplot(data = mrs_walrand_top_words,
aes(x = reorder(word, n), # Set x-axis
y = n)) + # Set y-axis
geom_col() + # Create bars
coord_flip() + # Flip axes
labs(title = "Mrs. Walrand's Top Words", # Add title
subtitle = "From \"Motion Respecting the Trial and Condemnation of
Missionary Smith at Demerara\"", # Add subtitle
x = "Word", # Label x-axis
y = "Count") # Label y-axis
# Load Hansard data and metadata for the 1840s
data("hansard_1840")
data("speaker_metadata_1840")
data("debate_metadata_1840")
# Join the speaker and debate metadata to each decade of Hansard data
hansard_1820 <- hansard_1820 %>%
left_join(speaker_metadata_1820) %>%
left_join(debate_metadata_1820)
hansard_1830 <- hansard_1830 %>%
left_join(speaker_metadata_1830) %>%
left_join(debate_metadata_1830)
hansard_1840 <- hansard_1840 %>%
left_join(speaker_metadata_1840) %>%
left_join(debate_metadata_1840)
# Stack the debates for 1820, 1830, and 1840
hansard <- bind_rows(hansard_1820, hansard_1830, hansard_1840)
# Find all the prereform text and speaker names
prereform <- hansard %>%
select(sentence_id, speechdate, debate, text, speaker, suggested_speaker) %>% # Keep text, date, debate, and speaker information
filter(speechdate >= as.Date("1822-06-04"), # Start filter ten years before reform
speechdate < as.Date("1832-06-04")) %>% # End before the reform date
mutate(year = year(speechdate), # Extract the year
period = "prereform") # Label these speeches as prereform
# Find all the postreform text and speaker names using similar code
postreform <- hansard %>%
select(sentence_id, speechdate, debate, text, speaker, suggested_speaker) %>%
filter(speechdate >= as.Date("1832-06-04"), # Start on the reform date
speechdate <= as.Date("1842-06-04")) %>% # End ten years after reform
mutate(year = year(speechdate),
period = "postreform") # Lavel these speeches as postreform
# Combine the prereform and postreform data
both_periods <- bind_rows(prereform, postreform)
# Break the text into individual words and count the words in each period
both_periods_word_count <- both_periods %>%
select(period, text) %>%
unnest_tokens(word, text) %>%
anti_join(stop_words, by = "word") %>%
count(period, word, name = "wordcount")
# Calculate the total number of words in each period
both_periods_word_count_totals <- both_periods_word_count %>%
group_by(period) %>%
summarize(total = sum(wordcount))
# Combine the prereform and postreform data
both_periods <- bind_rows(prereform, postreform)
# Break the text into individual words and count the words in each period
both_periods_word_count <- both_periods %>%
select(period, text) %>%
unnest_tokens(word, text) %>%
anti_join(stop_words, by = "word") %>%
count(period, word, name = "wordcount")
# Calculate the total number of words in each period
both_periods_word_count_totals <- both_periods_word_count %>%
group_by(period) %>%
summarize(total = sum(wordcount))
# Create a bar chart showing the total number of words in each period
ggplot(both_periods_word_count_totals, aes(x = period, y = total)) +
geom_col(aes(fill = period)) + # Create one bar for each period
scale_fill_grey() + # Use a grayscale fill
scale_y_continuous(labels = comma) + # Add commas to large numbers
geom_text(aes(label = paste0(comma(total), " words")), # Add the word count to each bar
colour = "white",
vjust = 1.5) +
labs(title = "How Many Words Were Spoken in Each Period?", # Add a title
x = "", # Keep x-axis label blank
y = "Words") # Add y-axis label
# Create a bar chart showing the total number of words in each period
ggplot(both_periods_word_count_totals, aes(x = period, y = total)) +
geom_col(aes(fill = period)) + # Create one bar for each period
scale_fill_grey() + # Use a grayscale fill
scale_x_discrete(limits = c("prereform", "postreform")) + # Put prereform on left side and postreform on the right
scale_y_continuous(labels = comma) + # Add commas to large numbers
geom_text(aes(label = paste0(comma(total), " words")), # Add the word count to each bar
colour = "white",
vjust = 1.5) +
labs(title = "How Many Words Were Spoken in Each Period?", # Add a title
x = "", # Keep x-axis label blank
y = "Words") # Add y-axis label
both_periods <- bind_rows(prereform, postreform)
# Count the number of words spoken by each speaker in each year and period
both_periods_speakers <- hansard_periods %>%
filter(!is.na(suggested_speaker),
str_trim(suggested_speaker) != "") %>%
unnest_tokens(word, text) %>% # Break text into individual words
count(period, suggested_speaker, year, name = "wordcount") # Count words by speaker and year
both_periods <- bind_rows(prereform, postreform)
# Count the number of words spoken by each speaker in each year and period
both_periods_speakers <- both_periods %>%
filter(!is.na(suggested_speaker),
str_trim(suggested_speaker) != "") %>%
unnest_tokens(word, text) %>% # Break text into individual words
count(period, suggested_speaker, year, name = "wordcount") # Count words by speaker and year
# Inspect the data
both_periods_speakers %>%
arrange(desc(wordcount)) %>% # Sort from highest to lowest word count
head(6) # Show the top 6 words
# Stack the prereform and postreform data
both_periods <- bind_rows(prereform, postreform)
